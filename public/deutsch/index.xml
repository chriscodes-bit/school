    <item>
      <title>Die Tribute von Panem</title>
      <link>http://localhost:1313/school/deutsch/posts/die_tribute_von_panem/</link>
      <pubDate>Tue, 17 Feb 2026 12:23:51 +0100</pubDate>
      <guid>http://localhost:1313/school/deutsch/posts/die_tribute_von_panem/</guid>
      <description>&lt;h2 id=&#34;die-entstehung-von-panem-und-der-hungerspiele&#34;&gt;Die Entstehung von Panem und der Hungerspiele&lt;/h2&gt;
&lt;p&gt;&lt;strong&gt;Panem: Aus den Trümmern von Nordamerika entstanden, nach mehreren Katastrophen&lt;/strong&gt;&lt;/p&gt;
&lt;table&gt;
  &lt;thead&gt;
      &lt;tr&gt;
          &lt;th&gt;Katastrophen infolges des Klimawandels&lt;/th&gt;
          &lt;th&gt;Folgen&lt;/th&gt;
      &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
      &lt;tr&gt;
          &lt;td&gt;Dürrezeiten&lt;/td&gt;
          &lt;td&gt;Ressourcenknappheit, wenig landwirtschaftliche Erträge/Fläche, Tod durch Verhungern&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;Krieg&lt;/td&gt;
          &lt;td&gt;Zerstörung von Lebensraum (Städte, Häuser, Supermärkte..), Tod, d.h. weniger Arbeitskräfte, politische Maßnahmen, um weitere Kriege zu verhinden&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;Feuersbrünste&lt;/td&gt;
          &lt;td&gt;Zerstörung von Ernten und Häusern&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;Stürme&lt;/td&gt;
          &lt;td&gt;Migration, Hunger&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;Anstieg des Meeresspiegels&lt;/td&gt;
          &lt;td&gt;Kampf um Wohnraum und Nahrung&lt;/td&gt;
      &lt;/tr&gt;
  &lt;/tbody&gt;
&lt;/table&gt;
&lt;h2 id=&#34;ich-erzählerin-katniss-everdeen&#34;&gt;Ich-Erzählerin Katniss Everdeen&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;
&lt;p&gt;Aussehen:&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;Herkunft ihres Namens und seine Bedeutung:&lt;/p&gt;</description>
